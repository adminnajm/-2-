{
  "cleanUrls": true,
  "trailingSlash": true,
  "rewrites": [
    { "source": "/services/", "destination": "/services/index.html" },
    { "source": "/services/tanks/", "destination": "/services/tanks/index.html" },
    { "source": "/services/ac-curtains/", "destination": "/services/ac-curtains/index.html" },
    { "source": "/services/pest-control/", "destination": "/services/pest-control/index.html" },
    { "source": "/services/moving/", "destination": "/services/moving/index.html" },
    { "source": "/blog/", "destination": "/blog/index.html" },
    { "source": "/blog/best-tank-cleaning-riyadh/", "destination": "/blog/best-tank-cleaning-riyadh/index.html" },
    { "source": "/contact/", "destination": "/contact/index.html" },
    { "source": "/faq/", "destination": "/faq/index.html" },
    { "source": "/terms/", "destination": "/terms/index.html" },
    { "source": "/privacy/", "destination": "/privacy/index.html" },
    { "source": "/accessibility/", "destination": "/accessibility/index.html" },
    { "source": "/cancellation/", "destination": "/cancellation/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
